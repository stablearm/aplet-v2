    {
      "name": "Content Bots",
      "description": "AI-powered content bot management. Create auto-posting bots for Telegram channels with topic selection, signature customization, rate limiting, and subscription-based access. Merges the 7-step Telegram wizard into one API call.",
      "item": [
        {
          "name": "Create Content Bot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
